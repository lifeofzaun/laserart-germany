/* ============================================================
   LaserArt Font Preview – CSS (Shopify safe)
   Datei: assets/font-preview-la.css.liquid
   ============================================================ */

/* ============================================================
   LASERART COLOR SYSTEM
   ============================================================ */
:root{
  --la-bg-main: #F7F1E3;
  --la-bg-card: #FFFFFF;
  --la-bg-soft: #F0E6D2;
  --la-accent: #5E7458;
  --la-text: #000000;

  --la-radius-lg: 22px;
  --la-radius-md: 16px;
}

/* ============================================================
   FULL PAGE BACKGROUND (nur für diese Section)
   - löst dein "immer noch weiss" Problem, weil es fixed den Viewport färbt
   ============================================================ */
.la-font-preview{
  position: relative;
}
.la-font-preview__bg{
  position: fixed;
  inset: 0;
  background: var(--la-bg-main);
  z-index: -1;
}

