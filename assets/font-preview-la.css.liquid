/* ----------------------------
   LAYOUT / UI
   ---------------------------- */
.font-preview-wrap{
  max-width: 1200px;
  margin: 0 auto;
  padding: 28px 18px 34px;
  border-radius: 26px;
  background: rgba(240,230,210,.55); /* F0E6D2 "soft" */
  border: 1px solid rgba(94,116,88,.18);
  box-shadow: 0 18px 60px rgba(0,0,0,.06);
}

.font-preview-head{
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-bottom: 16px;
}

.font-preview-title{
  font-size: 28px;
  font-weight: 700;
  margin: 0;
  letter-spacing: -0.02em;
  color: var(--la-text);
}

.font-preview-input-wrap{display:flex;flex-direction:column;gap:8px}

.font-preview-hint{
  font-size: 12px;
  color: rgba(0,0,0,.55);
}

.font-preview-input{
  width: 100%;
  padding: 14px 16px;
  font-size: 18px;
  border: 1px solid rgba(94,116,88,.35);
  border-radius: 14px;
  background: #fff;
  color: var(--la-text);
  transition: border-color .2s ease, box-shadow .2s ease;
}

.font-preview-input:focus{
  outline: none;
  border-color: var(--la-accent);
  box-shadow: 0 0 0 3px rgba(94,116,88,.22);
}

.font-preview-grid{
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 14px;
}

.font-preview-card{
  border: 1px solid rgba(94,116,88,.22);
  border-radius: var(--la-radius-lg);
  padding: 14px 14px 12px;
  background: var(--la-bg-card);
  box-shadow: 0 10px 26px rgba(0,0,0,.06);
}

.font-preview-name{
  font-size: 12px;
  font-weight: 700;
  color: var(--la-accent);
  letter-spacing: .02em;
  margin-bottom: 8px;
}

.font-preview-meta{margin-top:10px}
.font-preview-badge{
  display:inline-block;
  font-size:11px;
  padding:6px 10px;
  border-radius:999px;
  background: rgba(94,116,88,.10);
  color: rgba(0,0,0,.72);
  border: 1px solid rgba(94,116,88,.18);
}

/* ----------------------------
   TEXT BOX (Auto-Fit Area)
   - JS skaliert font-size runter, bis es passt
   ---------------------------- */
.font-preview-text{
  color: var(--la-text);
  white-space: pre-wrap;          /* erlaubt echte Zeilenumbrüche */
  overflow-wrap: anywhere;
  word-break: break-word;

  display: flex;
  align-items: center;
  min-height: 120px;              /* Raum für 2 Zeilen */
  padding: 6px 2px;

  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;

  font-size: var(--base-size, 54px);
  line-height: var(--base-line, 1.10);
}

/* ============================================================
