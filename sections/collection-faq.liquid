{%- liquid
  assign faq_set_ref = collection.metafields.custom.faq_set
  assign faq_items = nil

  if faq_set_ref != blank
    assign faq_set = faq_set_ref.value
    if faq_set != blank and faq_set.items != blank
      assign faq_items = faq_set.items.value
    endif
  endif
-%}

{%- if faq_items != blank and faq_items.size > 0 -%}
<section class="collection-faq">
  <div class="collection-faq__inner">
    {% if section.settings.heading != blank %}
      <h2 class="collection-faq__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="collection-faq__grid">
      {%- for item in faq_items limit: section.settings.max_items -%}
        <div class="collection-faq__card">
          <h3 class="collection-faq__question">
            {{ item.question }}
          </h3>

          <div class="collection-faq__answer rte">
            {%- comment -%}
              Rich text aus Metaobjects immer via metafield_tag rendern,
              sonst erscheint JSON im Frontend.
            {%- endcomment -%}
            {{ item.answer | metafield_tag }}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>

  {%- if section.settings.enable_faq_schema -%}
    {%- capture faq_schema -%}
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {%- for item in faq_items limit: section.settings.max_items -%}
          {
            "@type": "Question",
            "name": {{ item.question | strip_html | strip | json }},
            "acceptedAnswer": {
              "@type": "Answer",
              "text": {{ item.answer | metafield_text | strip | json }}
            }
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    }
    {%- endcapture -%}
    <script type="application/ld+json">{{ faq_schema }}</script>
  {%- endif -%}
</section>

<style>
.collection-faq{
  background:#F1EDE7;
  padding:60px 0;
}
.collection-faq__inner{
  max-width:1100px;
  margin:0 auto;
  padding:0 16px;
}
.collection-faq__heading{
  font-size:32px;
  line-height:1.2;
  margin:0 0 28px;
}
.collection-faq__grid{
  display:grid;
  grid-template-columns:repeat(2, minmax(0, 1fr));
  gap:28px 44px;
}
.collection-faq__card{
  padding-bottom:18px;
  border-bottom:1px solid rgba(0,0,0,0.12);
}
.collection-faq__question{
  font-size:16px;
  font-weight:700;
  margin:0 0 10px;
}
.collection-faq__answer{
  line-height:1.7;
}
.collection-faq__answer p{
  margin:0 0 10px;
}
.collection-faq__answer p:last-child{
  margin-bottom:0;
}
@media (max-width: 900px){
  .collection-faq{
    padding:44px 0;
  }
  .collection-faq__grid{
    grid-template-columns:1fr;
    gap:18px;
  }
  .collection-faq__heading{
    font-size:26px;
    margin-bottom:18px;
  }
}
</style>
{%- endif -%}

{% schema %}
{
  "name": "FAQ – Kollektion",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Häufige Fragen"
    },
    {
      "type": "range",
      "id": "max_items",
      "label": "Anzahl FAQ-Einträge",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "checkbox",
      "id": "enable_faq_schema",
      "label": "FAQ-Schema (JSON-LD) ausgeben",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "FAQ – Kollektion"
    }
  ]
}
{% endschema %}
