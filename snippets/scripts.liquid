{%- if defer_homepage_secondary_scripts -%}
  <script>
    (function loadHomepageSecondaryThemeScripts() {
      const scriptUrls = [
        {{ 'quick-add.js' | asset_url | json }},
        {{ 'variant-picker.js' | asset_url | json }},
        {{ 'product-card.js' | asset_url | json }},
        {{ 'product-form.js' | asset_url | json }},
        {{ 'media.js' | asset_url | json }},
        {{ 'product-price.js' | asset_url | json }},
        {{ 'product-sku.js' | asset_url | json }},
        {{ 'product-title-truncation.js' | asset_url | json }},
        {{ 'product-inventory.js' | asset_url | json }},
        {{ 'show-more.js' | asset_url | json }},
        {{ 'component-quantity-selector.js' | asset_url | json }},
        {{ 'rte-formatter.js' | asset_url | json }}
        {%- if settings.show_add_discount_code -%}
          , {{ 'cart-discount.js' | asset_url | json }}
        {%- endif -%}
      ];

      let scriptsLoaded = false;

      function appendModuleScript(src) {
        if (!src || document.querySelector('script[data-homepage-deferred-src="' + src + '"]')) return;

        const script = document.createElement('script');
        script.src = src;
        script.type = 'module';
        script.fetchPriority = 'low';
        script.dataset.homepageDeferredSrc = src;
        document.head.appendChild(script);
      }

      function cleanup() {
        window.removeEventListener('pointerdown', loadScripts, listenerOptions);
        window.removeEventListener('keydown', loadScripts, listenerOptions);
        window.removeEventListener('touchstart', loadScripts, listenerOptions);
      }

      function loadScripts() {
        if (scriptsLoaded) return;
        scriptsLoaded = true;
        cleanup();
        scriptUrls.forEach(appendModuleScript);
      }

      const listenerOptions = { passive: true, once: true };

      window.addEventListener('pointerdown', loadScripts, listenerOptions);
      window.addEventListener('keydown', loadScripts, listenerOptions);
      window.addEventListener('touchstart', loadScripts, listenerOptions);

      if ('requestIdleCallback' in window) {
        requestIdleCallback(loadScripts, { timeout: 1200 });
      } else {
        window.setTimeout(loadScripts, 1200);
      }
    })();
  </script>
