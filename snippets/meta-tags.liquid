<meta charset="utf-8">
<meta
  http-equiv="X-UA-Compatible"
  content="IE=edge"
>
<meta
  name="viewport"
  content="width=device-width,initial-scale=1"
>
<meta
  name="view-transition"
  content="same-origin"
>
<meta
  name="theme-color"
  content="{{ settings.color_schemes['scheme-1'].settings.background }}"
>

{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  assign og_description = page_description | default: shop.description | default: shop.name
  assign meta_description_content = page_description | default: ''
  assign page_handle = ''

  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif

  if request.page_type == 'page' and page != blank
    assign page_handle = page.handle | default: ''
  endif

  if meta_description_content == blank
    if request.page_type == 'page' and page != blank and page.content != blank
      assign meta_description_content = page.content | strip_html | strip_newlines | truncate: 160
    elsif request.page_type == 'page' and page != blank
      case page_handle
        when 'kontakt'
          assign meta_description_content = 'Kontaktiere LaserArt Germany bei Fragen zu Bestellungen, Personalisierungen, Sonderwünschen oder Produkten. Direkt, persönlich und ohne Umwege.'
        when 'hochzeit'
          assign meta_description_content = 'Personalisierte Hochzeitsgeschenke aus Holz für Brautpaar, Feier und Tischdeko. Handgefertigt mit Gravur, Namen und Datum von LaserArt Germany.'
      endcase
    elsif request.page_type == 'article' and article != blank
      assign meta_description_content = article.excerpt_or_content | strip_html | strip_newlines | truncate: 160
    elsif request.page_type == 'blog' and blog != blank
      assign meta_description_content = blog.title | append: ' | Inspirationen, Ideen und persoenliche Geschenkwelten von LaserArt Germany.' | truncate: 160
    elsif request.page_type == 'collection' and collection != blank and collection.description != blank
      assign meta_description_content = collection.description | strip_html | strip_newlines | truncate: 160
    elsif request.page_type == 'product' and product != blank and product.description != blank
      assign meta_description_content = product.description | strip_html | strip_newlines | truncate: 160
    else
      assign meta_description_content = shop.description | default: shop.name | strip_html | strip_newlines | truncate: 160
    endif
  endif

  assign og_description = meta_description_content | default: og_description | strip_html | strip_newlines | truncate: 160
%}

<meta
  property="og:site_name"
  content="{{ shop.name }}"
>
<meta
  property="og:url"
  content="{{ og_url }}"
>
<meta
  property="og:title"
  content="{{ og_title | escape }}"
>
<meta
  property="og:type"
  content="{{ og_type }}"
>
<meta
  property="og:description"
  content="{{ og_description | escape }}"
>

{%- if page_image -%}
  {%- assign resolved_og_image = page_image | image_url: width: 1200 -%}
  {%- assign resolved_og_image = resolved_og_image | replace: '&amp;', '&' | strip -%}
  {%- unless resolved_og_image contains '://' -%}
    {%- if resolved_og_image contains '//' -%}
      {%- assign resolved_og_image = 'https:' | append: resolved_og_image -%}
    {%- else -%}
      {%- assign resolved_og_image = request.origin | append: resolved_og_image -%}
    {%- endif -%}
  {%- endunless -%}
  {%- assign resolved_og_image = resolved_og_image | replace: 'http://', 'https://' -%}
  <meta
    property="og:image"
    content="{{ resolved_og_image }}"
  >
  <meta
    property="og:image:secure_url"
    content="{{ resolved_og_image }}"
  >
  <meta
    property="og:image:width"
    content="1200"
  >
  <meta
    property="og:image:height"
    content="{{ 1200 | divided_by: page_image.aspect_ratio | round }}"
  >
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta
    property="og:price:amount"
    content="{{ product.price | money_without_currency | strip_html }}"
  >
  <meta
    property="og:price:currency"
    content="{{ cart.currency.iso_code }}"
  >
{%- endif -%}

{%- if settings.social_twitter_link != blank -%}
  <meta
    name="twitter:site"
    content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}"
  >
{%- endif -%}
<meta
  name="twitter:card"
  content="summary_large_image"
>
<meta
  name="twitter:title"
  content="{{ og_title | escape }}"
>
<meta
  name="twitter:description"
  content="{{ og_description | escape }}"
>

<title>
  {{ page_title }}
  {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
  {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
  {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
</title>

<link
  rel="canonical"
  href="{{ canonical_url }}"
>

{% if meta_description_content != blank %}
  <meta
    name="description"
    content="{{ meta_description_content | strip_html | strip_newlines | truncate: 160 | escape }}"
  >
{% endif %}
