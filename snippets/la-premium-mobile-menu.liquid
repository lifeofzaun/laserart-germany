  </div>

  <div class="la-premium-mobile__sections">
    <details class="la-premium-mobile__section">
      <summary>Hochzeit</summary>
      {% render 'la-premium-menu-panel', menu_key: 'hochzeit', mobile: true %}
    </details>
    <details class="la-premium-mobile__section">
      <summary>Taufe & Geburt</summary>
      {% render 'la-premium-menu-panel', menu_key: 'taufe-geburt', mobile: true %}
    </details>
    <details class="la-premium-mobile__section">
